---
import SectionHeader from "@/components/site/SectionHeader.astro";
import ResponsiveImage from "@/components/site/ResponsiveImage.astro";

const highlights = [
  { num: "01", title: "Qualidade Premium", text: "Extensões e produtos de excelência." },
  { num: "02", title: "Cuidado Personalizado", text: "Cada cliente, uma experiência única em Vila Real." },
  { num: "03", title: "Experiência & Arte", text: "Profissionalismo e técnica apurada." },
];
---

<section id="sobre" class="section-padding section-defer bg-gradient-soft">
  <div class="container-tight">
    <SectionHeader
      eyebrow="Sobre Nós"
      title="Beleza que transforma a tua"
      highlight="autoestima"
      description="No coração de Vila Real, dedicamo-nos a realçar a beleza natural de cada mulher com técnica, carinho e produtos premium."
      align="center"
      class="mb-14 md:mb-16"
    />

    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="reveal image-frame">
        <ResponsiveImage
          name="hair-02"
          alt="Trabalho de extensões na JL e Extensões em Vila Real"
          sizes="(max-width: 1024px) 100vw, 50vw"
          class="aspect-[4/5] w-full rounded-[1.75rem] object-cover shadow-elegant"
        />
        <div class="corner-accent absolute -bottom-5 -right-2 card-luxury px-6 py-4 sm:-right-4">
          <p class="font-serif text-3xl leading-none text-gold">+10</p>
          <p class="mt-1 text-[10px] uppercase tracking-widest text-muted-foreground">Anos a transformar</p>
        </div>
      </div>

      <div class="reveal space-y-6">
        <p class="text-base leading-relaxed text-foreground/80 md:text-lg">
          A <strong class="font-medium text-foreground">JL e Extensões</strong> é um estúdio dedicado à beleza feminina,
          especialista em extensões de cabelo de alta qualidade. Localizado em <strong class="font-medium text-foreground">Vila Real</strong>, Portugal.
        </p>
        <p class="text-base leading-relaxed text-muted-foreground">
          Mais do que serviços, oferecemos uma transformação completa — técnica apurada, produtos premium e
          o cuidado que mereces para te sentires radiante.
        </p>

        <ul class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
          {highlights.map((item) => (
            <li class="card-luxury-hover group p-5">
              <span class="mb-3 inline-block font-serif text-sm text-gold/60 transition-colors group-hover:text-gold">{item.num}</span>
              <p class="mb-1 font-serif text-lg text-foreground">{item.title}</p>
              <p class="text-xs leading-relaxed text-muted-foreground">{item.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>