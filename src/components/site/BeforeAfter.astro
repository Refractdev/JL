---
import ResponsiveImage from "@/components/site/ResponsiveImage.astro";

interface Props {
  before: string;
  after: string;
  beforeAlt?: string;
  afterAlt?: string;
}

const {
  before,
  after,
  beforeAlt = "Antes",
  afterAlt = "Depois",
} = Astro.props;
---

<div
  data-before-after
  class="reveal relative mx-auto aspect-[4/5] w-full max-w-3xl cursor-ew-resize select-none overflow-hidden rounded-[1.75rem] border border-border/60 shadow-elegant touch-none"
  role="img"
  aria-label="Comparação antes e depois — arrasta para ver a transformação"
>
  <ResponsiveImage
    name={after}
    alt={afterAlt}
    sizes="(max-width: 768px) 100vw, 48rem"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div data-before-clip class="absolute inset-0 overflow-hidden" style="clip-path: inset(0 50% 0 0)">
    <ResponsiveImage
      name={before}
      alt={beforeAlt}
      sizes="(max-width: 768px) 100vw, 48rem"
      class="absolute inset-0 h-full w-full object-cover"
    />
  </div>

  <div
    data-before-handle
    class="absolute inset-y-0 z-10 w-0.5 -translate-x-1/2 bg-white shadow-[0_0_16px_rgba(0,0,0,0.3)]"
    style="left: 50%"
    aria-hidden="true"
  >
    <div class="absolute left-1/2 top-1/2 flex h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-[3px] border-white bg-gradient-gold shadow-gold">
      <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path d="M8 9l-4 3 4 3M16 9l4 3-4 3"></path>
      </svg>
    </div>
  </div>

  <span class="pointer-events-none absolute left-4 top-4 rounded-full border border-border/50 bg-background/95 px-4 py-1.5 text-[10px] font-semibold uppercase tracking-[0.22em] text-foreground shadow-soft">
    Antes
  </span>
  <span class="pointer-events-none absolute right-4 top-4 rounded-full bg-gradient-gold px-4 py-1.5 text-[10px] font-semibold uppercase tracking-[0.22em] text-white shadow-gold">
    Depois
  </span>
</div>

<script>
  (function () {
    var slider = document.querySelector("[data-before-after]");
    if (!slider) return;

    var position = 50;
    var dragging = false;
    var clip = slider.querySelector("[data-before-clip]");
    var handle = slider.querySelector("[data-before-handle]");

    function setPosition(pct) {
      position = Math.min(100, Math.max(0, pct));
      if (clip) clip.style.clipPath = "inset(0 " + (100 - position) + "% 0 0)";
      if (handle) handle.style.left = position + "%";
    }

    function updateFromEvent(clientX) {
      var rect = slider.getBoundingClientRect();
      setPosition(((clientX - rect.left) / rect.width) * 100);
    }

    slider.addEventListener("pointerdown", function (e) {
      dragging = true;
      slider.setPointerCapture(e.pointerId);
      updateFromEvent(e.clientX);
    });
    slider.addEventListener("pointermove", function (e) {
      if (!dragging) return;
      updateFromEvent(e.clientX);
    });
    slider.addEventListener("pointerup", function () {
      dragging = false;
    });
    slider.addEventListener("pointercancel", function () {
      dragging = false;
    });

    setPosition(50);
  })();
</script>