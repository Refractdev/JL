---
import SectionHeader from "@/components/site/SectionHeader.astro";
import { business, services } from "@/lib/site";
import { whatsappLink, WHATSAPP_DISPLAY } from "@/lib/whatsapp";
---

<section id="contacto" class="section-padding section-defer bg-gradient-soft">
  <div class="container-tight">
    <SectionHeader
      eyebrow="Contacto"
      title="Vamos"
      highlight="conversar"
      description="Marca o teu serviço pelo WhatsApp ou preenche o formulário — respondemos o mais rápido possível."
      align="center"
      class="mb-12 md:mb-14"
    />

    <div class="grid gap-6 lg:grid-cols-2 lg:gap-8">
      <div class="reveal card-luxury p-6 md:p-8">
        <h3 class="mb-6 font-serif text-2xl text-foreground">Informações</h3>

        <ul class="space-y-3">
          <li class="info-row">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-gold-soft text-gold" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.5 20.25a8.25 8.25 0 0115 0"/></svg>
            </span>
            <div>
              <p class="text-[10px] uppercase tracking-widest text-muted-foreground">Responsável</p>
              <p class="font-medium text-foreground">{business.owner}</p>
            </div>
          </li>
          <li class="info-row">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-gold-soft text-gold" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            </span>
            <div>
              <p class="text-[10px] uppercase tracking-widest text-muted-foreground">Telefone / WhatsApp</p>
              <a href={`tel:${business.phone}`} class="font-medium text-foreground transition-colors hover:text-gold">{WHATSAPP_DISPLAY}</a>
            </div>
          </li>
          <li class="info-row">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-gold-soft text-gold" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </span>
            <div>
              <p class="text-[10px] uppercase tracking-widest text-muted-foreground">Email</p>
              <a href={`mailto:${business.email}`} class="break-all font-medium text-foreground transition-colors hover:text-gold">{business.email}</a>
            </div>
          </li>
          <li class="info-row">
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-gold-soft text-gold" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </span>
            <div>
              <p class="text-[10px] uppercase tracking-widest text-muted-foreground">Morada</p>
              <p class="leading-relaxed text-foreground">
                {business.address.street}, {business.address.postalCode} {business.address.city}, Portugal
              </p>
            </div>
          </li>
        </ul>

        <div class="mt-5 rounded-2xl border border-border/50 bg-secondary/40 p-4">
          <p class="mb-2 text-[10px] uppercase tracking-widest text-muted-foreground">Horário</p>
          <ul class="space-y-1 text-sm text-foreground">
            {business.hours.map((h) => (
              <li class="flex justify-between gap-4">
                <span class="text-muted-foreground">{h.days}</span>
                <span class="font-medium">{h.time}</span>
              </li>
            ))}
          </ul>
        </div>

        <a
          href={whatsappLink("Olá! Gostaria de marcar um serviço.")}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary mt-6"
        >
          Falar no WhatsApp
        </a>

        <div class="mt-6 overflow-hidden rounded-2xl border border-border/60 shadow-soft" data-map-facade>
          <button
            type="button"
            data-map-load
            class="group relative flex h-52 w-full flex-col items-center justify-center gap-3 bg-secondary/60 text-foreground transition-colors hover:bg-secondary"
          >
            <img
              src="/images/hair-04-400w.webp"
              alt=""
              class="absolute inset-0 h-full w-full object-cover opacity-40 grayscale"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <span class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-gold text-white shadow-gold" aria-hidden="true">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            </span>
            <span class="relative z-10 text-sm font-semibold">Abrir no Google Maps</span>
          </button>
        </div>
      </div>

      <form
        id="contact-form"
        class="reveal card-luxury p-6 md:p-8"
        novalidate
        data-whatsapp-url={whatsappLink("")}
      >
        <div class="mb-6 border-b border-border/50 pb-5">
          <h3 class="font-serif text-2xl text-foreground">Pedido de marcação</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Preenche os dados e abrimos o WhatsApp com a mensagem pronta.
          </p>
        </div>

        <p data-contact-error hidden class="mb-4 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700" role="alert"></p>

        <div class="space-y-4">
          <div>
            <label for="contact-name" class="mb-2 block text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">
              Nome <span class="text-red-400">*</span>
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="w-full rounded-xl border border-border/80 bg-background px-4 py-3.5 text-base transition-all duration-200 focus:border-gold/40 focus:outline-none focus:ring-2 focus:ring-gold/20"
              placeholder="O teu nome"
            />
          </div>

          <div>
            <label for="contact-phone" class="mb-2 block text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">
              Telefone <span class="text-red-400">*</span>
            </label>
            <input
              id="contact-phone"
              name="phone"
              type="tel"
              required
              autocomplete="tel"
              inputmode="tel"
              class="w-full rounded-xl border border-border/80 bg-background px-4 py-3.5 text-base transition-all duration-200 focus:border-gold/40 focus:outline-none focus:ring-2 focus:ring-gold/20"
              placeholder="+351 ..."
            />
          </div>

          <div>
            <label for="contact-service" class="mb-2 block text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">
              Serviço pretendido
            </label>
            <select
              id="contact-service"
              name="service"
              class="w-full rounded-xl border border-border/80 bg-background px-4 py-3.5 text-base transition-all duration-200 focus:border-gold/40 focus:outline-none focus:ring-2 focus:ring-gold/20"
            >
              {services.map((s) => (
                <option value={s}>{s}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="contact-message" class="mb-2 block text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">
              Mensagem
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows={4}
              class="w-full resize-none rounded-xl border border-border/80 bg-background px-4 py-3.5 text-base transition-all duration-200 focus:border-gold/40 focus:outline-none focus:ring-2 focus:ring-gold/20"
              placeholder="Conta-nos o que procuras..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full min-h-12 rounded-full bg-foreground px-6 py-3.5 text-base font-semibold text-background transition-all duration-300 hover:bg-foreground/90 active:scale-[0.98]"
          >
            Enviar via WhatsApp
          </button>
        </div>
      </form>
    </div>
  </div>
</section>