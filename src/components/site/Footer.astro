---
import { business } from "@/lib/site";
import { WHATSAPP_DISPLAY } from "@/lib/whatsapp";
---

<footer class="relative bg-foreground text-background/85">
  <div class="footer-gradient-border" aria-hidden="true"></div>

  <!-- Subtle background pattern -->
  <div class="footer-pattern pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>

  <div class="container-tight relative grid gap-12 py-14 md:grid-cols-12 md:py-16">
    <div class="md:col-span-5">
      <div class="mb-5 flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-full border border-gold/30 bg-gold/10 font-serif text-sm text-gold-light">JL</span>
        <div>
          <p class="font-serif text-2xl text-background">
            JL <span class="text-gold-light">&amp;</span> Extensões
          </p>
          <p class="text-[9px] uppercase tracking-[0.28em] text-background/45">Estúdio de Beleza &middot; Vila Real</p>
        </div>
      </div>
      <p class="max-w-sm text-sm leading-relaxed text-background/65">
        Especialistas em extensões de cabelo e serviços de beleza premium. Transformamos a tua autoestima com cuidado e arte em Vila Real, Portugal.
      </p>
      <div class="mt-6 flex gap-3">
        <a href={business.social.instagram} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full border border-background/15 text-background/60 transition-colors hover:border-gold/40 hover:text-gold-light" aria-label="Instagram">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href={business.social.facebook} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full border border-background/15 text-background/60 transition-colors hover:border-gold/40 hover:text-gold-light" aria-label="Facebook">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>
    </div>

    <div class="md:col-span-3">
      <p class="mb-5 text-[10px] font-semibold uppercase tracking-[0.28em] text-gold-light">Contacto</p>
      <ul class="space-y-3 text-sm">
        <li>
          <a href={`tel:${business.phone}`} class="text-background/75 transition-colors hover:text-background">{WHATSAPP_DISPLAY}</a>
        </li>
        <li>
          <a href={`mailto:${business.email}`} class="text-background/75 transition-colors hover:text-background break-all">{business.email}</a>
        </li>
        <li class="text-background/75 leading-relaxed">
          {business.address.street}, {business.address.postalCode} {business.address.city}, Portugal
          <a
            href="https://maps.google.com/?q=Av.+Gen.+Alves+Ro%C3%A7adas+15,+5000-687+Vila+Real"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 inline-flex items-center gap-1 text-xs text-gold-light/60 transition-colors hover:text-gold-light"
          >
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Ver no mapa
          </a>
        </li>
      </ul>
    </div>

    <div class="md:col-span-4">
      <p class="mb-5 text-[10px] font-semibold uppercase tracking-[0.28em] text-gold-light">Navegação</p>
      <ul class="grid grid-cols-2 gap-x-4 gap-y-2.5 text-sm">
        <li><a href="/" class="text-background/75 transition-colors hover:text-background">Início</a></li>
        <li><a href="/#sobre" class="text-background/75 transition-colors hover:text-background">Sobre</a></li>
        <li><a href="/extensoes-cabelo-vila-real" class="text-background/75 transition-colors hover:text-background">Extensões</a></li>
        <li><a href="/maquilhagem-vila-real" class="text-background/75 transition-colors hover:text-background">Maquilhagem</a></li>
        <li><a href="/unhas-vila-real" class="text-background/75 transition-colors hover:text-background">Unhas</a></li>
        <li><a href="/#contacto" class="text-background/75 transition-colors hover:text-background">Contacto</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-background/10">
    <div class="container-tight flex flex-col items-center justify-between gap-2 py-5 text-xs text-background/45 sm:flex-row">
      <span>&copy; {new Date().getFullYear()} JL e Extensões &middot; Todos os direitos reservados</span>
      <span class="text-background/35">Feito com cuidado em Vila Real</span>
    </div>
  </div>
</footer>