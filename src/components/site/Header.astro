---
import { navLinks } from "@/lib/site";
import { whatsappLink } from "@/lib/whatsapp";
import MobileNav from "@/components/site/MobileNav.astro";
---

<header
  class="sticky top-0 z-50 border-b border-transparent bg-background/95 backdrop-blur-xl transition-all duration-500 data-[scrolled=true]:border-border/80 data-[scrolled=true]:shadow-soft md:bg-background/85 md:backdrop-blur-2xl md:data-[scrolled=true]:bg-background/95"
  id="site-header"
  aria-label="Navegação principal"
>
  <div class="container-tight flex h-[4.25rem] items-center justify-between sm:h-[4.75rem]">
    <a href="/" class="group flex items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center rounded-full border border-gold/20 bg-gradient-gold-soft font-serif text-sm text-gold transition-all duration-300 md:group-hover:scale-105 md:group-hover:shadow-gold" aria-hidden="true">
        JL
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-serif text-lg text-foreground transition-colors sm:text-xl">
          JL <span class="text-gold">&amp;</span> Extensões
        </span>
        <span class="text-[9px] uppercase tracking-[0.28em] text-muted-foreground">
          Estúdio de Beleza
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Menu principal">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        id="theme-toggle"
        class="hidden h-10 w-10 items-center justify-center rounded-xl border border-border/60 text-foreground/70 transition-colors hover:border-gold/30 hover:text-gold sm:inline-flex"
        aria-label="Alternar modo escuro"
      >
        <svg class="h-4 w-4 sun-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <svg class="h-4 w-4 moon-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>
      <a
        href={whatsappLink("Olá! Gostaria de marcar um serviço.")}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary hidden !min-h-10 !px-5 !py-2 !text-sm sm:inline-flex"
      >
        WhatsApp
      </a>
      <MobileNav links={navLinks} whatsappHref={whatsappLink("Olá! Gostaria de marcar um serviço.")} />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 16 ? "true" : "false";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  // Dark mode toggle
  const toggle = document.getElementById("theme-toggle");
  if (toggle) {
    toggle.classList.remove("hidden");
    const sunIcon = toggle.querySelector(".sun-icon");
    const moonIcon = toggle.querySelector(".moon-icon");
    const html = document.documentElement;

    function updateIcons() {
      const isDark = html.classList.contains("dark");
      sunIcon?.classList.toggle("hidden", !isDark);
      moonIcon?.classList.toggle("hidden", isDark);
    }

    updateIcons();

    toggle.addEventListener("click", () => {
      html.classList.toggle("dark");
      // Sync data-theme
      html.setAttribute("data-theme", "light");
      if (html.classList.contains("dark")) {
        html.setAttribute("data-theme", "dark");
      } else {
        html.setAttribute("data-theme", "light");
      }
      updateIcons();
    });

    // Listen for system changes when in system mode
    window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
      if (html.getAttribute("data-theme") === "system") {
        updateIcons();
      }
    });
  }
</script>