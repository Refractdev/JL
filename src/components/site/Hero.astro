---
import { whatsappLink } from "@/lib/whatsapp";
import ResponsiveImage from "@/components/site/ResponsiveImage.astro";
---

<section
  id="inicio"
  class="relative flex min-h-[80svh] items-end overflow-hidden md:min-h-screen md:items-center"
>
  <!-- Background image mobile -->
  <div class="absolute inset-0 md:hidden">
    <ResponsiveImage
      name="hair-04"
      alt=""
      priority
      fill
      sizes="100vw"
      class="h-full w-full object-cover"
    />
  </div>

  <!-- Background video desktop -->
  <video
    class="absolute inset-0 hidden h-full w-full object-cover md:block"
    poster="/images/hair-04-800w.jpg"
    muted
    loop
    playsinline
    autoplay
    preload="metadata"
    aria-hidden="true"
  >
    <source src="/videos/video-01.mp4" type="video/mp4" />
  </video>

  <!-- Animated gradient overlay -->
  <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>

  <!-- Decorative radial gradient for depth -->
  <div
    class="pointer-events-none absolute -top-1/2 left-1/2 h-[80vh] w-[80vw] -translate-x-1/2 opacity-30 dark:opacity-20"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at center, hsl(38 52% 72% / 0.25), transparent 70%)"
  ></div>

  <div class="container-tight relative z-10 w-full pb-12 pt-28 sm:pb-16 sm:pt-32 md:pb-20">
    <div class="max-w-2xl md:max-w-3xl">
      <div class="reveal mb-6 flex flex-wrap items-center gap-3">
        <span class="pill-badge border-white/20 bg-white/10 text-white/90">
          Estúdio Premium
        </span>
        <span class="text-[11px] font-medium uppercase tracking-[0.2em] text-white/60">Vila Real</span>
      </div>

      <h1 class="reveal mb-5 font-serif text-[2rem] leading-[1.1] text-white sm:text-5xl md:text-6xl lg:text-[3.5rem]">
        Realça a tua beleza com<br />
        <span class="mt-1 inline-block bg-gradient-to-r from-[hsl(var(--gold-light))] to-white bg-clip-text text-transparent">
          JL e Extensões
        </span>
      </h1>

      <p class="reveal mb-8 max-w-lg text-[15px] leading-relaxed text-white/85 sm:text-lg">
        Extensões de cabelo premium, cuidado capilar especializado e todos os serviços de beleza num só lugar.
      </p>

      <div class="reveal mb-10 flex flex-col gap-3 sm:flex-row sm:gap-4">
        <a
          href={whatsappLink("Olá! Gostaria de marcar um serviço na JL e Extensões.")}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Marcar no WhatsApp
        </a>
        <a href="/#servicos" class="btn-ghost-light">
          Ver serviços
        </a>
      </div>

      <div class="reveal scrollbar-hide flex gap-2 overflow-x-auto sm:grid sm:max-w-md sm:grid-cols-3 sm:gap-3 sm:overflow-visible">
        <div class="stat-chip-hero min-w-[5.5rem] shrink-0 sm:min-w-0">
          <span class="font-serif text-xl text-gold-light">+10</span>
          <span class="text-[9px] uppercase tracking-wider text-white/60">Anos</span>
        </div>
        <div class="stat-chip-hero min-w-[5.5rem] shrink-0 sm:min-w-0">
          <span class="font-serif text-xl text-gold-light">100%</span>
          <span class="text-[9px] uppercase tracking-wider text-white/60">Natural</span>
        </div>
        <div class="stat-chip-hero min-w-[5.5rem] shrink-0 sm:min-w-0">
          <span class="font-serif text-xl text-gold-light">5&#9733;</span>
          <span class="text-[9px] uppercase tracking-wider text-white/60">Cuidado</span>
        </div>
      </div>
    </div>
  </div>

  <a
    href="/#sobre"
    class="scroll-hint absolute bottom-6 left-1/2 z-10 hidden -translate-x-1/2 flex-col items-center gap-2 text-white/50 transition-colors hover:text-white/80 md:flex"
    aria-label="Descobre mais"
  >
    <span class="text-[9px] uppercase tracking-[0.3em]">Scroll</span>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 14l-7 7m0 0l-7-7"/></svg>
  </a>
</section>