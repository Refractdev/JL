---
import type { navLinks } from "@/lib/site";

interface Props {
  links: typeof navLinks;
  whatsappHref: string;
}

const { links, whatsappHref } = Astro.props;
---

<div class="lg:hidden" data-mobile-nav>
  <button
    type="button"
    data-mobile-nav-toggle
    aria-label="Abrir menu"
    aria-expanded="false"
    aria-controls="mobile-nav-panel"
    class="flex min-h-11 min-w-11 items-center justify-center rounded-xl border border-border/60 text-foreground transition-colors hover:border-gold/30 hover:bg-secondary"
  >
    <svg data-icon-menu class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
    <svg data-icon-close class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18"></path>
    </svg>
  </button>

  <div
    id="mobile-nav-panel"
    data-mobile-nav-panel
    hidden
    class="mobile-nav-panel fixed inset-0 top-[4.25rem] z-50 bg-background/98 backdrop-blur-2xl sm:top-[4.75rem]"
    role="dialog"
    aria-modal="true"
    aria-label="Menu de navegação"
  >
    <nav class="container-tight flex flex-col gap-1 py-8" aria-label="Menu mobile">
      {
        links.map((link) => (
          <a
            href={link.href}
            data-mobile-nav-link
            class="group flex items-center justify-between rounded-2xl border border-transparent px-5 py-4 text-lg font-medium text-foreground/85 transition-all hover:border-border hover:bg-secondary/60"
          >
            {link.label}
            <svg class="h-4 w-4 text-gold/40 transition-transform group-hover:translate-x-0.5 group-hover:text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        ))
      }
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        data-mobile-nav-link
        class="btn-primary mt-6"
      >
        Marcar no WhatsApp
      </a>
    </nav>
  </div>
</div>

<script>
  const root = document.querySelector("[data-mobile-nav]");
  if (root) {
    const toggle = root.querySelector("[data-mobile-nav-toggle]");
    const panel = root.querySelector("[data-mobile-nav-panel]");
    const iconMenu = root.querySelector("[data-icon-menu]");
    const iconClose = root.querySelector("[data-icon-close]");
    const navLinks = root.querySelectorAll("[data-mobile-nav-link]");
    let open = false;

    function setOpen(val) {
      open = val;
      if (toggle && panel) {
        panel.hidden = !open;
        panel.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
        toggle.setAttribute("aria-label", open ? "Fechar menu" : "Abrir menu");
      }
      iconMenu?.classList.toggle("hidden", open);
      iconClose?.classList.toggle("hidden", !open);
      document.body.style.overflow = open ? "hidden" : "";
      // Focus trap
      if (open && toggle) {
        setTimeout(() => toggle.focus(), 100);
      }
    }

    toggle?.addEventListener("click", () => setOpen(!open));

    navLinks.forEach((link) => link.addEventListener("click", () => setOpen(false)));

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  }
</script>