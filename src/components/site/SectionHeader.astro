---
interface Props {
  eyebrow: string;
  title: string;
  highlight?: string;
  description?: string;
  align?: "center" | "left";
  class?: string;
}

const { eyebrow, title, highlight, description, align = "center", class: className = "" } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class={`reveal max-w-2xl ${alignClass} ${className}`}>
  <div class={`mb-4 flex items-center gap-3 ${align === "center" ? "justify-center" : ""}`}>
    <span class="gold-line" aria-hidden="true"></span>
    <span class="section-eyebrow">{eyebrow}</span>
    <span class="gold-line" aria-hidden="true"></span>
  </div>
  <h2 class="font-serif text-[1.75rem] leading-[1.15] text-foreground sm:text-4xl lg:text-[2.75rem]">
    {title}
    {highlight && <> <em class="not-italic text-gold">{highlight}</em></>}
  </h2>
  {description && (
    <p class="mt-4 text-base leading-relaxed text-muted-foreground">{description}</p>
  )}
</div>