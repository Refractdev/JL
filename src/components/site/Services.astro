---
import SectionHeader from "@/components/site/SectionHeader.astro";
import ResponsiveImage from "@/components/site/ResponsiveImage.astro";
import { serviceCards } from "@/lib/site";
import { whatsappLink } from "@/lib/whatsapp";
---

<section id="servicos" class="section-padding section-defer bg-background">
  <div class="container-tight">
    <SectionHeader
      eyebrow="Os Nossos Serviços"
      title="Tudo o que precisas, num"
      highlight="só lugar"
      description="Especialistas em extensões de cabelo e dedicados a cada detalhe da tua beleza em Vila Real."
      align="center"
      class="mb-14 md:mb-16"
    />

    <!-- Featured service: Extensões de Cabelo -->
    <div class="reveal mb-10 grid gap-4 lg:grid-cols-12 lg:gap-5">
      <article class="group relative min-h-[340px] overflow-hidden rounded-[1.75rem] shadow-elegant lg:col-span-7 lg:min-h-[420px]">
        <ResponsiveImage
          name="extension-process-02"
          alt="Extensões de cabelo em Vila Real"
          sizes="(max-width: 1024px) 100vw, 58vw"
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 will-change-transform md:group-hover:scale-[1.03]"
        />
        <!-- Dramatic gradient overlay with brand color -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 via-40% to-black/20"></div>
        <!-- Subtle gold accent line -->
        <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-gold" aria-hidden="true"></div>
        <div class="relative flex h-full flex-col justify-end p-6 text-white md:p-9">
          <span class="pill-badge mb-3 w-fit border-gold/40 bg-gold/15 text-gold-light">Especialidade da Casa</span>
          <h3 class="mb-2 font-serif text-2xl md:text-4xl">Extensões de Cabelo</h3>
          <p class="mb-6 max-w-md text-sm leading-relaxed text-white/85 md:text-base">
            Cabelo natural premium, aplicação profissional e resultados deslumbrantes que respeitam o teu cabelo.
          </p>
          <a href="/extensoes-cabelo-vila-real" class="btn-primary !w-fit !text-sm">
            Saber mais &rarr;
          </a>
        </div>
      </article>

      <div class="grid grid-cols-2 gap-4 lg:col-span-5 lg:grid-cols-1 lg:gap-5">
        <div class="group overflow-hidden rounded-[1.25rem] shadow-soft">
          <ResponsiveImage
            name="materials-01"
            alt="Variedade de cores de extensões"
            thumb
            sizes="(max-width: 1024px) 50vw, 25vw"
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 will-change-transform md:group-hover:scale-105 lg:aspect-auto lg:h-52"
          />
        </div>
        <div class="group overflow-hidden rounded-[1.25rem] shadow-soft">
          <ResponsiveImage
            name="hair-03"
            alt="Resultado de extensões"
            thumb
            sizes="(max-width: 1024px) 50vw, 25vw"
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 will-change-transform md:group-hover:scale-105 lg:aspect-auto lg:h-52"
          />
        </div>
      </div>
    </div>

    <!-- Service cards grid -->
    <div class="scrollbar-hide -mx-5 flex gap-4 overflow-x-auto px-5 pb-3 sm:mx-0 sm:grid sm:grid-cols-2 sm:overflow-visible sm:px-0 lg:grid-cols-3">
      {
        serviceCards.map((service) => {
          const href = "link" in service ? service.link : whatsappLink(service.message);
          const external = !("link" in service);
          return (
            <a
              href={href}
              {...external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
              class="reveal card-luxury-hover group w-[80vw] shrink-0 overflow-hidden sm:w-auto"
            >
              <div class="relative aspect-[16/10] overflow-hidden">
                <ResponsiveImage
                  name={service.image}
                  alt={service.title}
                  thumb
                  sizes="(max-width: 640px) 80vw, 33vw"
                  class="h-full w-full object-cover transition-transform duration-500 will-change-transform md:group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 transition-opacity duration-300 md:group-hover:opacity-100"></div>
              </div>
              <div class="border-t border-border/50 p-5">
                <h3 class="mb-1.5 font-serif text-xl text-foreground">{service.title}</h3>
                <p class="mb-4 text-sm leading-relaxed text-muted-foreground">{service.description}</p>
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-gold">
                  Marcar
                  <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>