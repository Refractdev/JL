---
import "../styles/global.css";
import type { PageSeo } from "@/lib/seo";
import { getCanonical, getJsonLd } from "@/lib/seo";
import { SITE_URL, business } from "@/lib/site";
import SkipLink from "@/components/site/SkipLink.astro";
import Header from "@/components/site/Header.astro";
import Footer from "@/components/site/Footer.astro";
import FloatingWhatsApp from "@/components/site/FloatingWhatsApp.astro";

interface Props {
  seo: PageSeo;
  showHeader?: boolean;
  showFooter?: boolean;
  showWhatsApp?: boolean;
}

const {
  seo,
  showHeader = true,
  showFooter = true,
  showWhatsApp = true,
} = Astro.props;

const canonical = getCanonical(seo.path);
const ogImage = seo.ogImage.startsWith("http") ? seo.ogImage : `${SITE_URL}${seo.ogImage}`;
const jsonLd = getJsonLd(seo);
const isService = seo.schemaType === "service";

// For service pages, add article timestamps
const publishedDate = "2025-01-15";
const modifiedDate = new Date().toISOString().split("T")[0];
---

<!doctype html>
<html lang="pt-PT" data-theme="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta name="author" content={business.name} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="pt-PT" href={canonical} />

    <!-- Local SEO -->
    <meta name="geo.region" content="PT-17" />
    <meta name="geo.placename" content="Vila Real" />
    <meta name="geo.position" content="41.2958;-7.7462" />
    <meta name="ICBM" content="41.2958, -7.7462" />

    <!-- Open Graph -->
    <meta property="og:type" content={isService ? "article" : "website"} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:site_name" content={business.name} />

    {isService && (
      <>
        <meta property="article:published_time" content={publishedDate} />
        <meta property="article:modified_time" content={modifiedDate} />
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@jleextensoes" />
    <meta name="twitter:creator" content="@jleextensoes" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.ico" />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://instagram.com" />
    <link rel="dns-prefetch" href="https://facebook.com" />
    <link rel="dns-prefetch" href="https://wa.me" />

    <!-- Fonts: preload critical, load via swap -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <script is:inline>
      // Dark mode: respect system preference
      (function () {
        var theme = document.documentElement.getAttribute("data-theme");
        if (theme === "system") {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
          window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function (e) {
            if (e.matches) {
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.classList.remove("dark");
            }
          });
        }
      })();

      // Add .js class for JS-powered reveal animations
      document.documentElement.classList.add("js");
    </script>
    <SkipLink />
    {showHeader && <Header />}
    <main id="main-content">
      <slot />
    </main>
    {showFooter && <Footer />}
    {showWhatsApp && <FloatingWhatsApp />}
    <script src="/scripts/main.js" defer></script>
  </body>
</html>