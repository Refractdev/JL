---
import BaseLayout from "@/layouts/BaseLayout.astro";

const seo = {
  title: "Página não encontrada | JL e Extensões",
  description: "A página que procuras não existe. Visita o nosso estúdio de beleza em Vila Real.",
  path: "/404",
  keywords: "jl e extensões, beleza vila real",
  ogImage: "/og-image.jpg",
  schemaType: "home" as const,
};
---

<BaseLayout seo={seo}>
  <section class="flex min-h-[70vh] flex-col items-center justify-center px-6 py-24 text-center">
    <span class="pill-badge mb-6">Erro 404</span>
    <h1 class="mb-4 font-serif text-4xl text-foreground md:text-5xl">Página não encontrada</h1>
    <p class="mb-10 max-w-md text-muted-foreground">
      A página que procuras não existe ou foi movida. Volta ao início e marca o teu serviço connosco.
    </p>
    <a href="/" class="btn-primary">Voltar ao início</a>
  </section>
</BaseLayout>