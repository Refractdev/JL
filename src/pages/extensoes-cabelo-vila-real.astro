---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/site/SectionHeader.astro";
import ResponsiveImage from "@/components/site/ResponsiveImage.astro";
import { getPageSeo } from "@/lib/seo";
import { whatsappLink } from "@/lib/whatsapp";

const seo = getPageSeo("/extensoes-cabelo-vila-real");

const benefits = [
  { title: "Cabelo 100% Natural", desc: "Utilizamos cabelo humano da mais alta qualidade para garantir um toque e brilho perfeitos." },
  { title: "Aplicação Segura", desc: "A nossa técnica protege o teu cabelo natural, sem o danificar ou enfraquecer." },
  { title: "Durabilidade", desc: "Com a manutenção correta, as tuas extensões vão acompanhar-te perfeitamente durante meses." },
];
---

<BaseLayout seo={seo}>
  <article class="pt-[4.25rem] sm:pt-[4.75rem]">
    <section class="section-padding">
      <div class="container-tight grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="reveal order-2 lg:order-1">
          <span class="pill-badge mb-5">Especialistas em Vila Real</span>
          <h1 class="mb-5 font-serif text-[1.85rem] leading-tight text-foreground sm:text-4xl lg:text-5xl">
            Extensões de Cabelo com Efeito <em class="not-italic text-gold">Natural</em>
          </h1>
          <p class="mb-8 text-base leading-relaxed text-muted-foreground md:text-lg">
            Queres cabelo longo e com volume, mas com aspeto 100% natural? No nosso estúdio em <strong class="text-foreground">Vila Real</strong>, somos especialistas em extensões de cabelo de alta qualidade. Trabalhamos com as melhores marcas para oferecer resultados que respeitam o teu cabelo e realçam a tua beleza natural.
          </p>
          <a
            href={whatsappLink("Olá! Gostaria de saber mais sobre as extensões de cabelo e marcar uma avaliação.")}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Marcar Avaliação
          </a>
        </div>
        <div class="reveal image-frame order-1 lg:order-2">
          <ResponsiveImage
            name="extension-process-02"
            alt="Aplicação de extensões de cabelo em Vila Real"
            priority
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="aspect-[4/5] w-full rounded-[1.75rem] object-cover shadow-elegant"
          />
        </div>
      </div>
    </section>

    <section class="section-padding bg-gradient-soft">
      <div class="container-tight">
        <SectionHeader
          eyebrow="Vantagens"
          title="Porquê colocar extensões"
          highlight="connosco?"
          description="Serviço premium em Vila Real, pensado para a tua confiança."
          align="center"
          class="mb-12"
        />
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {benefits.map((b, i) => (
            <div class="reveal card-luxury-hover p-7">
              <span class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-gradient-gold-soft font-serif text-sm text-gold">0{i + 1}</span>
              <h2 class="mb-2 font-serif text-xl">{b.title}</h2>
              <p class="text-sm leading-relaxed text-muted-foreground">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-tight grid items-center gap-12 lg:grid-cols-2">
        <div class="reveal grid grid-cols-2 gap-4">
          <ResponsiveImage name="extension-process-01" alt="Processo de aplicação de extensões de cabelo em Vila Real" thumb sizes="50vw" class="aspect-[3/4] w-full rounded-2xl object-cover shadow-soft" />
          <ResponsiveImage name="extension-process-03" alt="Resultado final de extensões de cabelo no estúdio JL e Extensões em Vila Real" thumb sizes="50vw" class="mt-8 aspect-[3/4] w-full rounded-2xl object-cover shadow-soft" />
        </div>
        <div class="reveal">
          <h2 class="mb-4 font-serif text-3xl text-foreground md:text-4xl">Transformações Reais em Vila Real</h2>
          <p class="mb-4 leading-relaxed text-muted-foreground">
            Analisamos cor, textura e densidade do teu cabelo para encontrar o tom exato e o método mais indicado. O nosso estúdio em Vila Real está equipado com tudo o que precisas para uma transformação completa e segura.
          </p>
          <a
            href={whatsappLink("Olá! Gostaria de enviar fotos do meu cabelo para um orçamento das extensões.")}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-semibold text-gold transition-opacity hover:opacity-80"
          >
            Pede o teu orçamento
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="section-padding bg-gradient-soft">
      <div class="container-tight">
        <SectionHeader
          eyebrow="FAQ"
          title="Perguntas Frequentes"
          highlight="Extensões"
          description="Respostas às dúvidas mais comuns sobre extensões de cabelo."
          align="center"
          class="mb-12"
        />
        <div class="mx-auto max-w-3xl space-y-4">
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">Quanto tempo duram as extensões de cabelo?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Com a manutenção correta, as extensões de cabelo natural duram entre 3 a 6 meses. Recomendamos revisões a cada 6-8 semanas para manter o aspeto impecável.</p>
          </div>
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">As extensões danificam o meu cabelo natural?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Não. A nossa técnica de aplicação protege o teu cabelo natural. Utilizamos métodos seguros como nós italiano e fita adesiva de qualidade premium.</p>
          </div>
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">Qual o preço das extensões de cabelo em Vila Real?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">O valor depende do comprimento, volume e tipo de aplicação. Contacta-nos pelo WhatsApp para uma avaliação personalizada e orçamento gratuito.</p>
          </div>
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">Posso pintar ou alisar as extensões?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Sim, as extensões de cabelo 100% natural podem ser pintadas, alisadas e modeladas com calor, tal como o teu cabelo natural.</p>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>