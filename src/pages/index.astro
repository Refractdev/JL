---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPageSeo } from "@/lib/seo";
import Hero from "@/components/site/Hero.astro";
import About from "@/components/site/About.astro";
import Services from "@/components/site/Services.astro";
import Contact from "@/components/site/Contact.astro";
import SectionHeader from "@/components/site/SectionHeader.astro";
import Gallery from "@/components/site/Gallery.astro";
import BeforeAfter from "@/components/site/BeforeAfter.astro";

const seo = getPageSeo("/");
---

<BaseLayout seo={seo}>
  <Hero />

  <!-- About -->
  <About />

  <!-- Services -->
  <Services />

  <!-- Before & After -->
  <section class="section-padding section-defer bg-gradient-soft">
    <div class="container-tight">
      <SectionHeader
        eyebrow="Transformação"
        title="Antes e"
        highlight="Depois"
        description="Arrasta para comparar — resultados reais de clientes que confiaram na nossa arte em Vila Real."
        align="center"
        class="mb-10 md:mb-12"
      />
      <BeforeAfter
        before="before-01"
        after="extension-process-03"
        beforeAlt="Cabelo antes do tratamento em Vila Real"
        afterAlt="Cabelo com extensões após tratamento"
      />
    </div>
  </section>

  <!-- Gallery -->
  <Gallery />

  <!-- Contact -->
  <Contact />
</BaseLayout>