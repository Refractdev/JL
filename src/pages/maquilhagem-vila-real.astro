---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/site/SectionHeader.astro";
import ResponsiveImage from "@/components/site/ResponsiveImage.astro";
import { getPageSeo } from "@/lib/seo";
import { whatsappLink } from "@/lib/whatsapp";

const seo = getPageSeo("/maquilhagem-vila-real");

const benefits = [
  { title: "Produtos Premium", desc: "Marcas de alta qualidade que garantem pele perfeita e sem brilhos indesejados durante horas." },
  { title: "Penteados & Make", desc: "Podemos conjugar a tua maquilhagem com um penteado incrível para saíres pronta do estúdio em Vila Real." },
  { title: "Estilo Personalizado", desc: "Do look natural ao glamour de Hollywood, adaptamos as técnicas ao que te faz sentir bem." },
  { title: "Noivas", desc: "Packs especiais de maquilhagem para noivas, com prova incluída para o teu grande dia." },
];
---

<BaseLayout seo={seo}>
  <article class="pt-[4.25rem] sm:pt-[4.75rem]">
    <section class="section-padding">
      <div class="container-tight grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="reveal image-frame order-2 lg:order-1">
          <ResponsiveImage
            name="gallery-makeup-01"
            alt="Maquilhagem profissional em Vila Real — JL e Extensões"
            priority
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="aspect-[4/5] w-full rounded-[1.75rem] object-cover shadow-elegant"
          />
        </div>
        <div class="reveal order-1 lg:order-2">
          <span class="pill-badge mb-5">Beleza para Eventos</span>
          <h1 class="mb-5 font-serif text-[1.85rem] leading-tight text-foreground sm:text-4xl lg:text-5xl">
            Maquilhagem que <em class="not-italic text-gold">Ilumina</em> o teu rosto
          </h1>
          <p class="mb-8 text-base leading-relaxed text-muted-foreground md:text-lg">
            Casamento, festa ou evento especial em <strong class="text-foreground">Vila Real</strong>? Maquilhagem com acabamento perfeito, duradouro e à prova de emoções. A nossa maquilhadora profissional realça a tua beleza natural com técnicas adaptadas a cada tipo de pele.
          </p>
          <a
            href={whatsappLink("Olá! Gostaria de saber preços e disponibilidade para maquilhagem.")}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Marcar Maquilhagem
          </a>
        </div>
      </div>
    </section>

    <section class="section-padding bg-gradient-soft">
      <div class="container-tight">
        <SectionHeader
          eyebrow="O Estúdio"
          title="Porquê escolher"
          highlight="connosco?"
          align="center"
          class="mb-12"
        />
        <div class="grid gap-5 sm:grid-cols-2">
          {benefits.map((b) => (
            <div class="reveal card-luxury-hover p-7">
              <h2 class="mb-2 font-serif text-xl">{b.title}</h2>
              <p class="text-sm leading-relaxed text-muted-foreground">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-padding">
      <div class="container-tight">
        <SectionHeader
          eyebrow="FAQ"
          title="Perguntas Frequentes"
          highlight="Maquilhagem"
          description="Respostas às dúvidas mais comuns sobre maquilhagem profissional."
          align="center"
          class="mb-12"
        />
        <div class="mx-auto max-w-3xl space-y-4">
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">Quanto tempo antes devo marcar maquilhagem para casamento?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Recomendamos marcação com pelo menos 2 meses de antecedência para noivas. Incluímos uma sessão de prova gratuita para garantir o look perfeito.</p>
          </div>
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">Fazem maquilhagem para eventos fora do estúdio?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">Sim, deslocamo-nos a eventos em Vila Real e arredores. Contacta-nos para mais informações sobre condições e valores.</p>
          </div>
          <div class="reveal card-luxury p-6">
            <h3 class="font-serif text-lg text-foreground">Quanto tempo dura a maquilhagem profissional?</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">A nossa maquilhagem tem duração de 8 a 12 horas, consoante o tipo de pele e produtos utilizados. Usamos primers e fixadores de longa duração.</p>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>